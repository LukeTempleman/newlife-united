{
  "name": "newlife-united-crm",
  "version": "1.0.0",
  "description": "CRM for Newlife United Church",
  "scripts": {
    "dev": "wrangler pages dev .",
    "deploy": "wrangler pages deploy . --project-name=newlife-united",
    "db:migrate": "wrangler d1 execute newlife-crm --remote --file=./db/schema.sql",
    "db:seed": "wrangler d1 execute newlife-crm --remote --file=./db/seed.sql",
    "db:events": "wrangler d1 execute newlife-crm --remote --file=./db/events-2026.sql"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "crm"
  ],
  "author": "Newlife United",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240419.0",
    "esbuild": "^0.20.2",
    "typescript": "^5.4.4",
    "wrangler": "^4.90.0"
  }
}
